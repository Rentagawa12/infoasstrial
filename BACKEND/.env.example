# Lost & Found @ TIP Manila - Environment Variables

# ── Server Configuration ──────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB Configuration ─────────────────────
# For local development:
MONGO_URI=mongodb://localhost:27017/lostandfound

# For production (MongoDB Atlas):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/lostandfound?retryWrites=true&w=majority

# ── JWT Configuration ─────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# ── Upload Configuration ──────────────────────
UPLOAD_MAX_SIZE=5242880  # 5MB in bytes
UPLOAD_DIR=uploads

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100   # General
AUTH_RATE_LIMIT_MAX=5          # Auth endpoints
ITEM_RATE_LIMIT_MAX=20         # Item creation per hour

# ── Logging ───────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs

# ── CORS Configuration ────────────────────────
# For development, use '*'. For production, specify specific origins:
CORS_ORIGIN=*
# CORS_ORIGIN=https://yourdomain.com

# ── Frontend URL ──────────────────────────────
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://yourdomain.com

# ── Monitoring & Analytics (Optional) ────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# DATADOG_API_KEY=your_datadog_api_key
