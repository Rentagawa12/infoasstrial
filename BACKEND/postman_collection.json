    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.collectionVariables.set('jwt_token', pm.response.json().token);",
                  "    console.log('✅ User registered successfully!');",
                  "    console.log('Token saved to environment');",
                  "}"
