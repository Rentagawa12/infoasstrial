              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"User1\",\n  \"email\": \"user1@tip.edu.ph\",\n  \"password\": \"Test1234567\"\n}",
